# WorkTrack Backend Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it's in .gitignore).

# === Server ===
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=info
TRUSTED_PROXIES=127.0.0.1

# === Database ===
DATABASE_URL=postgres://worktrack:worktrack@localhost:5432/worktrack?sslmode=disable
# Sized for the 8am peak: ~1000 machines heartbeating in a 60s window
# bursts ~17 inserts/s; 50 connections gives plenty of headroom.
DB_MAX_CONNECTIONS=50
DB_MIN_CONNECTIONS=10

# === Auth (admin dashboard) ===
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# === Agent ===
AGENT_TOKEN_LENGTH=64
ONBOARDING_CODE_TTL_HOURS=72

# === Email — Amazon SES SMTP (us-east-1, production access) ===
# Domain smartxcore.com is verified in SES. From-address must be on this domain.
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=WorkTrack <admin@smartxcore.com>
ALERT_EMAIL=admin@smartxcore.com
DASHBOARD_URL=https://smartxcore.com

# === Object storage (for installer + python.zip) ===
# Cloudflare R2 (S3-compatible) or AWS S3
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=worktrack-releases
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === Rate limiting ===
RATELIMIT_AGENT_PER_MINUTE=120
RATELIMIT_ADMIN_PER_MINUTE=60

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://smartxcore.com
