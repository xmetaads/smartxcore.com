<?xml version="1.0" encoding="utf-8"?>
<!--
  Smart Video MSIX package manifest.

  This is the file makeappx.exe consumes when packaging Smartcore.exe
  into a sideloadable .msix bundle. Same pattern Claude Desktop uses
  (see C:\Program Files\WindowsApps\Claude_<ver>_x64__<pubhash>\).

  Important fields:

    Identity.Publisher
        MUST exactly match the EV-cert subject DN. signtool /pa
        verifies the .msix's signature against this string at install
        time; any mismatch and Add-AppxPackage refuses with
        ERROR_INSTALL_PACKAGE_PUBLISHER_MISMATCH. The value below
        matches the Sectigo EV cert subject for "CÔNG TY TNHH DU LỊCH
        VÀ TỔ CHỨC SỰ KIỆN PROTEAM".

    Identity.Version
        Must be 4-part (a.b.c.d). Bump for each release.

    rescap:Capability runFullTrust
        Tells Windows the packaged process can call any Win32 API
        (we need this for ShellExecute/WebView2/file IO/HTTP).
        Without it MSIX would sandbox us into AppContainer, which
        blocks the AI bundle's installer from spawning child
        processes outside the package.

    Application.Executable
        Path to the EV-signed Smartcore.exe inside the package
        layout (VFS\ProgramFilesX64\SmartVideo\Smartcore.exe —
        see msix-pack.ps1). Filename stays Smartcore.exe so existing
        download URLs / shortcuts keep working; user-facing strings
        all say "Smart Video".

  Add-AppxPackage installs this in seconds and the user double-
  clicks the .msix file in Explorer; Windows shows its own clean
  install UI (no UAC prompt because it's a per-user MSIX install).
  Pattern verified live against Claude Desktop on this dev machine —
  same MSIX install flow, same publisher-hash directory under
  C:\Program Files\WindowsApps\.
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap uap10 rescap">

    <!--
      Publisher DN MUST match the EV cert's Subject distinguished
      name byte-for-byte. signtool /pa verifies the .msix's signature
      against this string at install time; any mismatch and
      Add-AppxPackage refuses with
      ERROR_INSTALL_PACKAGE_PUBLISHER_MISMATCH.

      The placeholder below is the SmartCore LLC US entity in clean
      ASCII so makeappx.exe accepts the manifest as structurally
      valid. Before EV-signing the .msix in production, replace this
      Publisher value with the EXACT subject DN reported by:

          certutil -dump <your-ev-cert>.cer

      Two quirks discovered the hard way:

      1. makeappx's Publisher validator does NOT accept non-ASCII
         bytes - not as raw UTF-8, not as XML numeric character
         references (&#xNNNN;). A cert with Vietnamese / CJK
         diacritics in CN/O/S must have those RDN values
         transliterated to ASCII at cert-issuance time, or MSIX is
         not a viable distribution channel for that cert.

      2. Quoting RDN values via &quot;...&quot; (the form used in
         signtool subject output for values containing commas) makes
         the validator reject the publisher with the same generic
         "naming rules" error. Use bare values (CN=SmartCore LLC,
         not CN="SmartCore LLC") if no embedded commas; if the value
         contains commas, escape them as \, instead.
    -->
    <Identity
        Name="SmartCoreLLC.SmartVideo"
        Publisher="CN=SmartCore LLC, O=SmartCore LLC, L=Watertown, S=South Dakota, C=US"
        Version="1.0.0.0"
        ProcessorArchitecture="x64" />

    <Properties>
        <DisplayName>Smart Video</DisplayName>
        <PublisherDisplayName>SmartCore LLC</PublisherDisplayName>
        <Logo>Assets\StoreLogo.png</Logo>
        <Description>Smart Video — the world's first AI video platform.</Description>
    </Properties>

    <Dependencies>
        <TargetDeviceFamily Name="Windows.Desktop"
                            MinVersion="10.0.17763.0"
                            MaxVersionTested="10.0.22000.0" />
    </Dependencies>

    <Resources>
        <Resource Language="en-US" />
    </Resources>

    <Applications>
        <Application Id="SmartVideo" Executable="VFS\ProgramFilesX64\SmartVideo\Smartcore.exe" EntryPoint="Windows.FullTrustApplication">
            <uap:VisualElements
                BackgroundColor="#0b0d12"
                DisplayName="Smart Video"
                Square150x150Logo="Assets\Square150x150Logo.png"
                Square44x44Logo="Assets\Square44x44Logo.png"
                Description="Smart Video — the world's first AI video platform.">
                <uap:DefaultTile ShortName="Smart Video" />
            </uap:VisualElements>
        </Application>
    </Applications>

    <Capabilities>
        <rescap:Capability Name="runFullTrust" />
    </Capabilities>
</Package>
